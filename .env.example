# ===== Application =====
NEXT_PUBLIC_APP_URL=https://www.dtsrinivas.com
NEXT_PUBLIC_APP_NAME="D.T. Srinivas Connect"

# ===== Database (Neon Postgres - free tier) =====
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# ===== Auth =====
NEXTAUTH_URL=https://www.dtsrinivas.com
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# ===== Admin bootstrap =====
ADMIN_EMAIL=admin@dtsrinivas.com
ADMIN_PASSWORD=ChangeMe!Strong#2026

# ===== SMS / OTP (MSG91 free trial, or Twilio) =====
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=DTSCNT
OTP_BYPASS_CODE=123456   # Dev only — disable in prod

# ===== Upstash Redis (free tier — rate limiting + OTP cache) =====
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===== OpenAI / Groq for chatbot (Groq free tier recommended) =====
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# ===== Email (Resend free tier) =====
RESEND_API_KEY=
